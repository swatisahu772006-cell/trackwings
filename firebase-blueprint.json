{
  "entities": {
    "Habit": {
      "title": "Habit",
      "description": "A habit defined by the user",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the habit" },
        "icon": { "type": "string", "description": "Emoji icon for the habit" },
        "color": { "type": "string", "description": "Hex color for the habit" },
        "userId": { "type": "string", "description": "UID of the owner" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "icon", "color", "userId", "createdAt"]
    },
    "Completion": {
      "title": "Completion",
      "description": "A record of a habit being completed on a specific date",
      "type": "object",
      "properties": {
        "habitId": { "type": "string", "description": "ID of the habit" },
        "date": { "type": "string", "description": "Date of completion (YYYY-MM-DD)" },
        "userId": { "type": "string", "description": "UID of the owner" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["habitId", "date", "userId", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role" }
      },
      "required": ["email", "displayName"]
    }
  },
  "firestore": {
    "/habits/{habitId}": {
      "schema": "Habit",
      "description": "User habits"
    },
    "/completions/{completionId}": {
      "schema": "Completion",
      "description": "Habit completion records"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
